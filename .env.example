# Copia este archivo como .env en tu proyecto local
# En Vercel agrega estas variables en Settings > Environment Variables

# URL del Web App de Google Apps Script (la obtienes al desplegarlo)
VITE_SCRIPT_URL=https://script.google.com/macros/s/TU_ID_AQUI/exec

# Token secreto (debe coincidir con SECRET_TOKEN en Code.gs)
VITE_TOKEN=CAMBIA_ESTE_TOKEN
